<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GGVolt.Client.ViewModels"
        xmlns:views="clr-namespace:GGVolt.Client.Views"
        x:Class="GGVolt.Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="GGVolt"
        Width="1200" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        Background="#770B0C10">

    <Grid>
        <!-- 🔒 AUTH OVERLAY -->
        <Panel IsVisible="{Binding IsNotAuthenticated}" Background="{StaticResource BG.Deep}">
            <views:AuthView DataContext="{Binding AuthPage}" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"/>
        </Panel>

        <!-- 🖥️ MAIN LAYOUT -->
        <Grid ColumnDefinitions="240,*" IsVisible="{Binding IsAuthenticated}">
            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource BG.Surface}" 
                    BorderBrush="{StaticResource Border.Weak}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12" Margin="16,24,16,16">
                        <TextBlock Text="GG⚡Volt" FontFamily="{StaticResource Font.Heading}" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource Volt.Cyan}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <Button Classes="GGVoltBtnSecondary" Content="🏪 Магазин" HorizontalAlignment="Stretch" Command="{Binding NavigateToStoreCommand}"/>
                        <Button Classes="GGVoltBtnSecondary" Content="📚 Библиотека" HorizontalAlignment="Stretch" Command="{Binding NavigateToLibraryCommand}"/>
                        <Button Classes="GGVoltBtnSecondary" Content="👥 Сообщество" HorizontalAlignment="Stretch" Command="{Binding NavigateToLibraryCommand}"/>
                        <Button Classes="GGVoltBtnSecondary" Content="⚙️ Настройки" HorizontalAlignment="Stretch" Command="{Binding NavigateToSettingsCommand}"/>
                        
                        <Border Height="1" Background="{StaticResource Border.Weak}" Margin="0,12"/>
                        <Button Classes="GGVoltBtnSecondary" Content="🚪 Выйти" HorizontalAlignment="Stretch" Command="{Binding LogoutCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
                <Border Grid.Row="0" Background="{StaticResource BG.Surface}" BorderBrush="{StaticResource Border.Weak}" BorderThickness="0,0,0,1" Padding="20,14">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Classes="GGVoltInput" Grid.Column="0" Watermark="🔍 Поиск..." Margin="0,0,16,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                            <TextBlock Text="💳 0 ₽" Foreground="{StaticResource Text.Primary}" VerticalAlignment="Center"/>
                            <Button Classes="GGVoltBtnSecondary" Content="🔔" Padding="8"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" VerticalContentAlignment="Stretch"/>

                <Border Grid.Row="2" Background="{StaticResource BG.Surface}" BorderBrush="{StaticResource Border.Weak}" BorderThickness="0,1,0,0" Padding="16,10">
                    <TextBlock Text="GGVolt v0.1.0-alpha | 🟢 Online" Foreground="{StaticResource Text.Secondary}" FontFamily="{StaticResource Font.Mono}" FontSize="11" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>