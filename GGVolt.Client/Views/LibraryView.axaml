<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GGVolt.Client.ViewModels"
             xmlns:models="clr-namespace:GGVolt.Client.Models.Api"
             x:Class="GGVolt.Client.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             Padding="24">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="📚 Моя библиотека" FontFamily="{StaticResource Font.Heading}" FontSize="28" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- 🟡 Загрузка (ВЫНЕСЕНА ИЗ ItemsControl!) -->
            <StackPanel Spacing="12" IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" Margin="0,40">
                <ProgressBar Classes="GGVoltProgress" Value="0" Maximum="100" Width="300" Height="6"/>
                <TextBlock Text="⏳ Загрузка библиотеки..." Foreground="{StaticResource Text.Secondary}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- 🔴 Ошибка -->
            <Border Background="#2A0000" CornerRadius="8" Padding="16" IsVisible="{Binding HasError}">
                <StackPanel Spacing="8">
                    <TextBlock Text="⚠️ Ошибка загрузки" Foreground="Red" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8A8A"/>
                    <Button Classes="GGVoltBtnSecondary" Content="Повторить" Command="{Binding LoadLibraryCommand}" Width="120"/>
                </StackPanel>
            </Border>

            <!-- ✅ Список -->
            <ItemsControl ItemsSource="{Binding Items}" IsVisible="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:LibraryItemDto">
                        <Border Classes="GGVoltCard" Width="240" Margin="0,0,16,16">
                            <StackPanel Spacing="10">
                                <Border Height="130" Background="{StaticResource BG.Hover}" CornerRadius="6"/>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource Text.Primary}" FontFamily="{StaticResource Font.Heading}" FontSize="16"/>
                                <TextBlock Text="{Binding Version}" Foreground="{StaticResource Text.Secondary}" FontSize="12"/>
                                <Button Classes="GGVoltBtnSecondary" Content="{Binding ActionText}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>