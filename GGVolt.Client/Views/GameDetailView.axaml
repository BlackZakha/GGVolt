<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GGVolt.Client.ViewModels"
             xmlns:api="using:GGVolt.Client.Models.Api"
             x:Class="GGVolt.Client.Views.GameDetailView"
             x:DataType="vm:GameDetailViewModel"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0">
            
            <!-- 🎨 БАННЕР -->
            <Border Height="400" Background="{StaticResource BG.Hover}" ClipToBounds="True">
                <Grid>
                    <Image Source="{Binding Game.CoverUrl}" Stretch="UniformToFill" Opacity="0.6"/>
                    <Border Background="{StaticResource BG.Deep}" Opacity="0.7"/>
                    
                    <StackPanel VerticalAlignment="Bottom" Margin="40" Spacing="16">
                        <Button Classes="GGVoltBtnSecondary" Content="← Назад" Command="{Binding GoBackCommand}" 
                                HorizontalAlignment="Left" Width="120" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="{Binding Game.Title}" FontFamily="{StaticResource Font.Heading}" 
                                   FontSize="48" FontWeight="Bold" Foreground="{StaticResource Text.Primary}" 
                                   TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding Game.Type, StringFormat='Тип: {0}'}" 
                                       Foreground="{StaticResource Volt.Cyan}" FontSize="14"/>
                            <TextBlock Text="{Binding Game.ReleaseDate, StringFormat='Дата выхода: {0:dd.MM.yyyy}'}" 
                                       Foreground="{StaticResource Text.Secondary}" FontSize="14"/>
                            <TextBlock Text="{Binding Game.Price, StringFormat='{}{0} ₽'}" 
                                       Foreground="{StaticResource Volt.Magenta}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 📄 КОНТЕНТ -->
            <Grid ColumnDefinitions="2*,1*" ColumnSpacing="40" RowSpacing="40" Margin="0,40">
                
                <!-- Левая колонка: Описание и скриншоты -->
                <StackPanel Grid.Column="0" Spacing="32" Margin="0,0,40,0">
                    
                    <!-- Описание -->
                    <StackPanel Spacing="12">
                        <TextBlock Text=" Описание" FontFamily="{StaticResource Font.Heading}" 
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text.Primary}"/>
                        <Border Classes="GGVoltCard" Padding="20">
                            <TextBlock Text="{Binding Game.Description}" Foreground="{StaticResource Text.Primary}" 
                                       FontSize="15" LineHeight="24" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Скриншоты -->
                    <StackPanel Spacing="12" IsVisible="{Binding HasScreenshots}">
                        <TextBlock Text=" Скриншоты" FontFamily="{StaticResource Font.Heading}" 
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text.Primary}"/>
                        <ItemsControl ItemsSource="{Binding Game.Screenshots}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280" Height="160" Background="{StaticResource BG.Hover}" 
                                            CornerRadius="8" Margin="0,0,16,16" ClipToBounds="True">
                                        <Image Source="{Binding}" Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Системные требования -->
                    <StackPanel Spacing="12" IsVisible="{Binding HasSystemRequirements}">
                        <TextBlock Text="⚙️ Системные требования" FontFamily="{StaticResource Font.Heading}" 
                                   FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text.Primary}"/>
                        
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                            <Border Grid.Column="0" Classes="GGVoltCard" Padding="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Минимальные" FontFamily="{StaticResource Font.Heading}" 
                                               FontSize="16" FontWeight="Bold" Foreground="{StaticResource Volt.Cyan}"/>
                                    <TextBlock Text="{Binding Game.SystemRequirements.Minimum}" 
                                               Foreground="{StaticResource Text.Primary}" FontSize="13" 
                                               TextWrapping="Wrap" FontFamily="{StaticResource Font.Mono}"/>
                                </StackPanel>
                            </Border>
                            
                            <Border Grid.Column="1" Classes="GGVoltCard" Padding="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Рекомендуемые" FontFamily="{StaticResource Font.Heading}" 
                                               FontSize="16" FontWeight="Bold" Foreground="{StaticResource Volt.Magenta}"/>
                                    <TextBlock Text="{Binding Game.SystemRequirements.Recommended}" 
                                               Foreground="{StaticResource Text.Primary}" FontSize="13" 
                                               TextWrapping="Wrap" FontFamily="{StaticResource Font.Mono}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>    

                <!-- Правая колонка: Кнопка покупки -->
                <Border Grid.Column="1" Classes="GGVoltCard" Padding="24" VerticalAlignment="Top">
                    <StackPanel Spacing="16">
                        <TextBlock Text=" Покупка" FontFamily="{StaticResource Font.Heading}" 
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource Text.Primary}"/>
                        
                        <Border Background="{StaticResource BG.Hover}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Цена" Foreground="{StaticResource Text.Secondary}" FontSize="12"/>
                                <TextBlock Text="{Binding Game.Price, StringFormat='{}{0} ₽'}" 
                                           Foreground="{StaticResource Volt.Cyan}" FontSize="28" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Button Classes="GGVoltBtnPrimary" Content="{Binding PurchaseButtonText}" 
                                Command="{Binding PurchaseCommand}" IsEnabled="{Binding CanPurchase}" 
                                HorizontalAlignment="Stretch" Padding="16"/>
                        
                        <TextBlock Text="Мгновенная доставка • Без DRM • Поддержка 24/7" 
                                   Foreground="{StaticResource Text.Secondary}" FontSize="11" 
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Ошибка -->
            <Border Background="#2A0000" CornerRadius="8" Padding="16" Margin="40,0,40,40" 
                    IsVisible="{Binding HasError}">
                <StackPanel Spacing="8">
                    <TextBlock Text="⚠️ Ошибка" Foreground="Red" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF8A8A" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>